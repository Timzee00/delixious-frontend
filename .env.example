# URL of your deployed (or local) Delixious backend, including /api
VITE_API_URL=http://localhost:5000/api

# Optional: enables live delivery tracking updates (Supabase Realtime) on the
# order tracking page. Use the SAME project as your backend, but the PUBLIC
# anon key only - never the service role key. Without these, tracking still
# works, it just needs a manual page refresh to see status changes.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
